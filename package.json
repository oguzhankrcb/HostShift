{
  "name": "hostshift",
  "version": "0.3.0",
  "description": "Read-only-source Ubuntu and Debian server migration tooling",
  "type": "module",
  "scripts": {
    "test": "make test-go",
    "check": "make test-go",
    "test:go": "make test-go",
    "docs:dev": "npm --prefix docs-site run dev",
    "docs:build": "npm --prefix docs-site run build",
    "docs:compose:config": "docker compose -f docs-site/compose.yml config",
    "docs:preview": "npm --prefix docs-site run preview"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0"
}
